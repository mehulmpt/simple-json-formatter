{
  "manifest_version": 3,
  "name": "Simple JSON Formatter",
  "version": "1.0",
  "description": "Formats JSON documents in the browser. Add #raw to URL to see raw JSON.",
  "author": "Mehul Mohan <mehulmpt@gmail.com>",
  "homepage_url": "https://github.com/mehulmpt/simple-json-formatter",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
